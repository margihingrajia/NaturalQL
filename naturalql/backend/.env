# ── Groq ───────────────────────────────────────────────
GROQ_API_KEY=Your_key_he
GROQ_MODEL=llama-3.1-8b-instant

# ── Database (choose one) ──────────────────────────────
DB_TYPE=sqlite
SQLITE_PATH=database/uploads/default.db

# Postgres (if DB_TYPE=postgres)
# POSTGRES_URL=postgresql://user:password@localhost:5432/mydb

# MySQL (if DB_TYPE=mysql)
# MYSQL_URL=mysql://user:password@localhost:3306/mydb

# ── App ────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
MAX_ROWS_RETURNED=500
SCHEMA_CACHE_PATH=database/schema_cache.json
